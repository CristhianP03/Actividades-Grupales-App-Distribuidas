\section{Paso 3 --- Contrato OpenAPI 3.0 (Especificación YAML)}
El contrato formal es la base para la interoperabilidad entre microservicios.

\begin{lstlisting}[language=XML, caption=main-contract.yaml - Especificacion OpenAPI]
openapi: 3.0.3
info:
  title: NetSupport Tech API - ISP Solution
  version: 2.1.0
  description: API Integral de Gestion de Tickets de Soporte Tecnico.
  contact:
    name: Departamento de Arquitectura UTEQ
    email: soporte@netsupport.ec

servers:
  - url: http://localhost:8080/api/v1
    description: API Gateway de Desarrollo Local

tags:
  - name: Autenticacion
    description: Gestion de sesiones y tokens.
  - name: Soporte
    description: Ciclo de vida de incidencias.

paths:
  /auth/login:
    post:
      tags: [Autenticacion]
      summary: Iniciar sesion
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/LoginInput'
      responses:
        '200':
          description: OK
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AuthResponse'

  /tickets:
    get:
      tags: [Soporte]
      summary: Listar tickets paginados
      responses:
        '200':
          description: OK
    post:
      tags: [Soporte]
      summary: Reportar nueva incidencia
      security: [{bearerAuth: []}]
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/TicketCreate'
      responses:
        '201':
          description: Creado con exito.

components:
  securitySchemes:
    bearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
  schemas:
    LoginInput:
      type: object
      required: [email, password]
      properties:
        email: {type: string, format: email}
        password: {type: string, format: password}
    TicketCreate:
      type: object
      required: [title, description]
      properties:
        title: {type: string, minLength: 10}
        description: {type: string}
\end{lstlisting}

