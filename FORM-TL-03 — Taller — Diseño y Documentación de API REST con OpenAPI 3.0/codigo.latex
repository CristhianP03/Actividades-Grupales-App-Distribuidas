\subsection{Orquestación con Docker Compose}
Se define la infraestructura multicontenedor para simular el entorno de producción en desarrollo local.

\begin{lstlisting}[language=XML, caption=docker-compose.yml - Infraestructura de Red]
version: '3.9'
services:
  auth-db:
    image: postgres:18-alpine
    container_name: netsupport-auth-db
    environment:
      POSTGRES_DB: auth_db
      POSTGRES_USER: admin_auth
      POSTGRES_PASSWORD: auth_secure_pass
    networks: [netsupport-mesh]

  ticket-db:
    image: postgres:18-alpine
    container_name: netsupport-ticket-db
    environment:
      POSTGRES_DB: ticket_db
      POSTGRES_USER: admin_ticket
      POSTGRES_PASSWORD: ticket_secure_pass
    volumes:
      - ./infra/init-tickets.sql:/docker-entrypoint-initdb.d/init.sql
    networks: [netsupport-mesh]

  kafka-broker:
    image: confluentinc/cp-kafka:7.6.0
    environment:
      KAFKA_BROKER_ID: 1
      KAFKA_ZOOKEEPER_CONNECT: zookeeper:2181
      KAFKA_ADVERTISED_LISTENERS: PLAINTEXT://kafka-broker:9092
    networks: [netsupport-mesh]

networks:
  netsupport-mesh:
    driver: bridge
\end{lstlisting}

