\section{Implementación del Backend: Capa de Dominio y Seguridad}
\subsection{Modelado de Entidades (JPA/Lombok)}
\begin{lstlisting}[language=Java, caption=Entidad de Negocio: Ticket.java]
package com.uteq.netsupport.model;

import jakarta.persistence.*;
import lombok.*;
import org.hibernate.annotations.CreationTimestamp;
import java.time.LocalDateTime;
import java.util.UUID;

@Entity
@Table(name = "tickets")
@Getter @Setter @NoArgsConstructor @AllArgsConstructor @Builder
public class Ticket {

    @Id
    @GeneratedValue(strategy = GenerationType.UUID)
    private UUID id;

    @Column(nullable = false, length = 150)
    private String title;

    @Column(columnDefinition = "TEXT", nullable = false)
    private String description;

    @Enumerated(EnumType.STRING)
    private TicketStatus status = TicketStatus.NEW;

    private String priority;

    @Column(name = "client_id", nullable = false)
    private UUID clientId;

    @ManyToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "technician_id")
    private Technician assignedTechnician;

    @CreationTimestamp
    private LocalDateTime createdAt;
}
\end{lstlisting}

\newpage
\subsection{Configuración de Seguridad Spring Security 7}
Se implementa una arquitectura Stateless basada en filtros JWT para proteger los endpoints de soporte.

\begin{lstlisting}[language=Java, caption=Clase de Configuracion de Seguridad]
@Configuration
@EnableWebSecurity
@EnableMethodSecurity
public class SecurityConfig {

    @Bean
    public SecurityFilterChain filterChain(HttpSecurity http) throws Exception {
        return http
            .csrf(AbstractHttpConfigurer::disable)
            .sessionManagement(s -> s.sessionCreationPolicy(SessionCreationPolicy.STATELESS))
            .authorizeHttpRequests(auth -> auth
                .requestMatchers("/api/v1/auth/**").permitAll()
                .requestMatchers(HttpMethod.POST, "/api/v1/tickets/**").hasRole("USER")
                .requestMatchers("/api/v1/admin/**").hasRole("ADMIN")
                .anyRequest().authenticated()
            )
            .addFilterBefore(new JwtAuthenticationFilter(), UsernamePasswordAuthenticationFilter.class)
            .build();
    }
}
\end{lstlisting}

\section{Paso 1 --- Identificar Recursos y Diseño de URIs}
En esta fase, mapeamos el dominio de soporte técnico a una interfaz RESTful semántica.

\begin{longtable}{@{}lll@{}}
\caption{Matriz de Diseño de URIs RESTful NetSupport} \\ \toprule
\textbf{Incorrecto (Estilo RPC)} & \textbf{Correcto (RESTful)} & \textbf{Justificación Técnica} \\ \midrule
POST /createTicket & POST /tickets & Verbo HTTP define la acción. \\
GET /getAllPendingTickets & GET /tickets?status=NEW & Filtros vía Query Params. \\
POST /assignTechToTicket & POST /tickets/\{id\}/assign & Recurso como sub-entidad. \\
DELETE /removeTicket/10 & DELETE /tickets/10 & Semántica nativa de DELETE. \\ \bottomrule
\end{longtable}

\section{Paso 2 --- Tabla de Endpoints del Microservicio}
\begin{longtable}{@{}llll@{}}
\caption{Catálogo de Endpoints de NetSupport} \\ \toprule
\textbf{Método} & \textbf{Ruta} & \textbf{Input (DTO)} & \textbf{Output (Status)} \\ \midrule
POST & /auth/login & LoginRequest & 200 Ok (Token JWT) \\
GET & /tickets & Query (page, size) & 200 Ok (Listado) \\
POST & /tickets & TicketRequest & 201 Created \\
GET & /tickets/\{id\} & PathVariable & 200 Ok / 404 \\
PATCH & /tickets/\{id\} & PartialUpdate & 200 Ok / 400 \\
DELETE & /tickets/\{id\} & PathVariable & 204 No Content \\ \bottomrule
\end{longtable}

