\subsection{Capa de Persistencia: Esquema SQL Detallado}
\begin{lstlisting}[language=SQL, caption=Script SQL de Inicialización de Tickets]
-- Extension para manejo de UUIDs
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";

-- Tabla Maestra de Tecnicos
CREATE TABLE technicians (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    full_name VARCHAR(120) NOT NULL,
    specialization VARCHAR(60) NOT NULL,
    status VARCHAR(20) DEFAULT 'AVAILABLE',
    email VARCHAR(100) UNIQUE NOT NULL
);

-- Tabla Core de Tickets de Soporte
CREATE TABLE tickets (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    title VARCHAR(150) NOT NULL,
    description TEXT NOT NULL,
    category VARCHAR(50), 
    priority VARCHAR(20),
    status VARCHAR(30) DEFAULT 'NEW',
    client_id UUID NOT NULL,
    technician_id UUID REFERENCES technicians(id),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Datos Semilla
INSERT INTO technicians (full_name, specialization, email) VALUES 
('Ing. Cristhian Pacheco', 'Infraestructura Fibra', 'cpacheco@netsupport.ec'),
('Ing. Carlos Carpio', 'Soporte Nivel 2', 'ccarpio@netsupport.ec');
\end{lstlisting}

